{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mogenius/renovate-config//presets/golang.json#main"
  ],
  "regexManagers": [
    {
      "fileMatch": ["^Justfile$", "^Dockerfile$"],
      "matchStrings": [
        "unpkg\\.com/(?<depName>[^@\"]+)@(?<currentValue>[^/\"]+)"
      ],
      "datasourceTemplate": "npm"
    },
    {
      "fileMatch": ["^Justfile$", "^Dockerfile$"],
      "matchStrings": [
        "\"(?<depName>react|react-dom)@(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "npm"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["registry.k8s.io/kubectl", "valkey"],
      "semanticCommitType": "fix"
    },
    {
      "matchDatasources": ["npm"],
      "semanticCommitType": "fix"
    }
  ]
}
